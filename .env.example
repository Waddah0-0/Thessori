# Qwen API (OpenAI-compatible)
QWEN_API_KEY=your_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Model category overrides (optional, fall back to QWEN_MODEL if omitted)
# QWEN_MODEL_PLUS=qwen-plus-2025-07-28
# QWEN_MODEL_MAX=qwen-max-latest

# Semantic Scholar (optional key for higher rate limits)
S2_API_KEY=

# Google Docs export (optional — only needed for the Google Doc export button)
GOOGLE_SERVICE_ACCOUNT_JSON=

# App
MAX_PAPERS=20
TOP_K_PAPERS=10
